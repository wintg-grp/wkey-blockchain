{
  "annotations": { "list": [] },
  "title": "WINTG — Besu Overview",
  "tags": ["wintg", "besu", "ibft2"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Hauteur de chaîne",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "besu_blockchain_height", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Peers",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "besu_network_peer_count", "refId": "A" }]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Blocs / sec (target = 0.33)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 6 },
      "targets": [{ "expr": "rate(besu_blockchain_height[1m])", "refId": "A", "legendFormat": "{{node}}" }]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Tx pool size",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 6 },
      "targets": [{ "expr": "besu_transaction_pool_transactions", "refId": "A", "legendFormat": "{{node}}" }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Gas utilisé / bloc",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 6 },
      "targets": [{ "expr": "besu_blockchain_difficulty_total", "refId": "A" }]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "JVM heap (MB)",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 6 },
      "targets": [{ "expr": "jvm_memory_bytes_used / 1024 / 1024", "refId": "A", "legendFormat": "{{area}}" }]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "CPU host (%)",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 6 },
      "targets": [{ "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)", "refId": "A", "legendFormat": "{{instance}}" }]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Disk usage (%)",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 6 },
      "targets": [{ "expr": "100 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"} * 100)", "refId": "A", "legendFormat": "{{instance}}" }]
    }
  ]
}
