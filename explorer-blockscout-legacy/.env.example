# =============================================================================
# Blockscout — variables d'environnement
# =============================================================================
# Copier en .env et remplir.
# =============================================================================

# Réseau cible
NETWORK_NAME=Mainnet                 # ou Testnet
CHAIN_ID=2280                        # ou 22800

# RPC du nœud Besu (utiliser http://localhost:8545 si Blockscout est sur la
# même machine que le nœud RPC, sinon l'IP/host accessible)
WINTG_RPC_URL=http://host.docker.internal:8545
WINTG_WS_URL=ws://host.docker.internal:8546

# PostgreSQL
DB_USER=blockscout
DB_PASSWORD=CHANGE_ME_STRONG_RANDOM
DB_NAME=blockscout

# Phoenix — clé secrète (≥ 64 chars). Générer avec :
#   openssl rand -base64 64
SECRET_KEY_BASE=CHANGE_ME_OPENSSL_RAND_BASE64_64
