# Normalize line endings on commit
*           text=auto eol=lf
*.bat       text eol=crlf
*.ps1       text eol=crlf
*.sh        text eol=lf
*.sol       text eol=lf
*.ts        text eol=lf
*.json      text eol=lf
*.md        text eol=lf

# Binary files
*.png       binary
*.jpg       binary
*.jpeg      binary
*.ico       binary
*.pdf       binary
*.zip       binary

# Generated / lockfiles
*.lock      linguist-generated=true
package-lock.json  linguist-generated=true
