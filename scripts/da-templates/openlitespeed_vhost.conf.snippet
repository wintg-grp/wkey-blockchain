
# =============================================================================
# WINTG reverse-proxy entries
# Append into the DirectAdmin custom openlitespeed_vhost.conf template.
# Each block is gated by SDOMAIN so it only renders on the matching vhost.
# =============================================================================

# --- Mainnet RPC --------------------------------------------------------------
|*if SDOMAIN="rpc.wintg.network"|
extProcessor BesuRpcMainnet {
  type                    proxy
  address                 127.0.0.1:8545
  maxConns                100
  pcKeepAliveTimeout      60
  initTimeout             60
  retryTimeout            0
  respBuffer              0
}
context / {
  type                    proxy
  handler                 BesuRpcMainnet
  addDefaultCharset       off
}
|*endif|

# --- Mainnet WebSocket --------------------------------------------------------
|*if SDOMAIN="ws.wintg.network"|
extProcessor BesuWsMainnet {
  type                    proxy
  address                 127.0.0.1:8546
  maxConns                100
  pcKeepAliveTimeout      60
  initTimeout             60
  retryTimeout            0
  respBuffer              0
}
context / {
  type                    proxy
  handler                 BesuWsMainnet
  addDefaultCharset       off
}
|*endif|

