# --- Explorer (Blockscout: frontend on 3000 + /api on 4000) -------------------
|*if SDOMAIN="scan.wintg.network"|
extProcessor BlockscoutFrontend {
  type                    proxy
  address                 127.0.0.1:3000
  maxConns                100
  pcKeepAliveTimeout      60
  initTimeout             60
  retryTimeout            0
  respBuffer              0
}
extProcessor BlockscoutApi {
  type                    proxy
  address                 127.0.0.1:4000
  maxConns                100
  pcKeepAliveTimeout      60
  initTimeout             60
  retryTimeout            0
  respBuffer              0
}
context /api/ {
  type                    proxy
  handler                 BlockscoutApi
  addDefaultCharset       off
}
context /socket/ {
  type                    proxy
  handler                 BlockscoutApi
  addDefaultCharset       off
}
context /graphiql {
  type                    proxy
  handler                 BlockscoutApi
  addDefaultCharset       off
}
context /metrics {
  type                    proxy
  handler                 BlockscoutApi
  addDefaultCharset       off
}
context / {
  type                    proxy
  handler                 BlockscoutFrontend
  addDefaultCharset       off
}
|*endif|

# --- Faucet (testnet) ---------------------------------------------------------
|*if SDOMAIN="faucet.wintg.network"|
extProcessor WintgFaucet {
  type                    proxy
  address                 127.0.0.1:4001
  maxConns                50
  pcKeepAliveTimeout      30
  initTimeout             30
  retryTimeout            0
  respBuffer              0
}
context / {
  type                    proxy
  handler                 WintgFaucet
  addDefaultCharset       off
}
|*endif|
