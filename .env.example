# =============================================================================
# WINTG Blockchain — Variables d'environnement
# =============================================================================
# Copier en .env et remplir les valeurs réelles. NE JAMAIS COMMITER .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Réseau (mainnet | testnet)
# -----------------------------------------------------------------------------
NETWORK=testnet
CHAIN_ID=22800                          # 2280 pour mainnet

# -----------------------------------------------------------------------------
# Wallet déployeur (déploie tous les contrats — adresses pré-allouées dans genesis)
# -----------------------------------------------------------------------------
DEPLOYER_ADDRESS=0x0000000000000000000000000000000000000000
DEPLOYER_PRIVATE_KEY=                   # ⚠️ chiffrer ou utiliser un Vault en production
DEPLOYER_PREFUND_WTG=10000              # WTG pré-alloués au déployeur (prélevés sur Liquidity)

# -----------------------------------------------------------------------------
# Validateurs initiaux IBFT 2.0 (CSV d'adresses checksum)
# -----------------------------------------------------------------------------
# Phase bootstrap : 1 validateur unique. Ajouter ", 0xXXX" pour étoffer.
VALIDATORS=0x0000000000000000000000000000000000000000

# -----------------------------------------------------------------------------
# Wallets multisig de la distribution
# -----------------------------------------------------------------------------
LIQUIDITY_MULTISIG_ADDRESS=0x0000000000000000000000000000000000000000
TREASURY_MULTISIG_ADDRESS=0x0000000000000000000000000000000000000000

# -----------------------------------------------------------------------------
# Genesis
# -----------------------------------------------------------------------------
# GENESIS_TIMESTAMP=1735689600          # Optionnel — défaut : timestamp courant

# -----------------------------------------------------------------------------
# RPC publics (pour Hardhat networks et scripts d'admin)
# -----------------------------------------------------------------------------
RPC_URL_MAINNET=https://rpc.wintg.network
RPC_URL_TESTNET=https://testnet-rpc.wintg.network

# -----------------------------------------------------------------------------
# Block explorer (Blockscout) — pour vérification automatique des sources
# -----------------------------------------------------------------------------
BLOCKSCOUT_API_URL=https://scan.wintg.network/api
BLOCKSCOUT_API_KEY=                     # Optionnel selon config Blockscout

# -----------------------------------------------------------------------------
# Monitoring / alertes
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=
