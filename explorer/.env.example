# =============================================================================
# WINTG Scan — explorer environment
# =============================================================================
# Copy to .env.local. None of these are secrets — they're inlined into the
# client bundle, so don't put any private keys here.
# =============================================================================

# Logo lives at public/<filename>. Update once you upload the real one.
NEXT_PUBLIC_LOGO_URL=/logo.png

# Social / external links (placeholders — leave empty to hide the icon)
NEXT_PUBLIC_TWITTER_URL=
NEXT_PUBLIC_DISCORD_URL=
NEXT_PUBLIC_TELEGRAM_URL=
NEXT_PUBLIC_GITHUB_URL=https://github.com/wintg-grp/wkey-blockchain
NEXT_PUBLIC_DOC_URL=https://doc.wintg.network

# RPC endpoints — defaults match the deployed chain. Override if you run
# the explorer against a fork or a local Besu.
NEXT_PUBLIC_MAINNET_RPC=https://rpc.wintg.network
NEXT_PUBLIC_MAINNET_WS=wss://ws.wintg.network
NEXT_PUBLIC_TESTNET_RPC=https://testnet-rpc.wintg.network
NEXT_PUBLIC_TESTNET_WS=wss://testnet-ws.wintg.network

# Default network when a user lands on the page (mainnet | testnet)
NEXT_PUBLIC_DEFAULT_NETWORK=mainnet
